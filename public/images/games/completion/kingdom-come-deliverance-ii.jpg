<div class="age-gate age-gate--page">
    <div class="age-gate__logo">
        <img src="/media/wjmdy10o/header-logo-desktop.png" class="age-gate__logo-img" alt="Header Logo Desktop" />
    </div>
    <h2 class="age-gate__heading">Kingdom Come: Deliverance II</h2>

        <form method="post" class="age-gate-form">

            <p class="age-gate__question">CONFIRM YOUR AGE</p>

            <div class="age-gate__error validation-summary-valid" data-valmsg-summary="true"><ul><li style="display:none"></li>
</ul></div>

            <fieldset class="age-gate-form__fieldset">
                <div class="age-gate-form__layout">
                    <div class="age-gate-form__group">
                        <label for="Year" class="age-gate-form__label">
                            Year
                        </label>
                        <input name="Year" placeholder="Year" type="text" class="age-gate-form__input" pattern="^(19[0-9]{2}|20([0-2][0-9]|3[0-5]))$" inputmode="numeric" required maxlength="4">
                    </div>
                    <div class="age-gate-form__group">
                        <label for="Month" class="age-gate-form__label">
                            Month
                        </label>
                        <input name="Month" placeholder="Month" type="text" class="age-gate-form__input" pattern="^(0?[1-9]|1[0-2])$" inputmode="numeric" required maxlength="2">
                    </div>
                    <div class="age-gate-form__group">
                        <label for="Day" class="age-gate-form__label">
                            Day
                        </label>
                        <input name="Day" placeholder="Day" type="text" class="age-gate-form__input" pattern="^(0?[1-9]|[12][0-9]|3[01])$" inputmode="numeric" required maxlength="2">
                    </div>
                </div>
            </fieldset>

            <button class="unbutton link btn btn--primary">
                <span class="link__text">Submit</span>
            </button>

