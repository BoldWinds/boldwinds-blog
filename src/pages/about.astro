---

import GameSection from "../components/about/GameSection.astro";
import Section from "../components/common/Section.astro";
import { aboutGameGroups } from "../data/aboutGames";
import Layout from "../layouts/Layout.astro";
import { getConfigurationCollection } from "../lib/utils";

const { data: config } = await getConfigurationCollection();
---

<Layout>
  <Fragment slot="head">
    <title>关于 • {config.personal.name}</title>
    <meta name="description" content="关于刘博文的个人介绍、生活兴趣与游戏收藏。" />
    <meta property="og:title" content={`关于 • ${config.personal.name}`} />
    <meta property="og:description" content="关于刘博文的个人介绍、生活兴趣与游戏收藏。" />
    <meta property="og:url" content={`${config.site.baseUrl}/about`} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={`关于 • ${config.personal.name}`} />
    <meta name="twitter:description" content="关于刘博文的个人介绍、生活兴趣与游戏收藏。" />
    <meta http-equiv="content-language" content="zh-CN" />
    <meta name="language" content="Chinese" />
    <link rel="canonical" href={`${config.site.baseUrl}/about`} />
  </Fragment>

  <Section class="py-4 my-8">
    <div class="flex items-center gap-4 pt-8 pb-16">
      <h1 class="font-display text-3xl leading-loose sm:text-4xl">关于</h1>
    </div>

    <div class="flex flex-col gap-10 leading-8">
      <div class="space-y-4 text-lg sm:text-xl">
        <p>人生不仅仅有工作和学习，我是:</p>
        <p>重度游戏爱好者，喜爱 MOBA、FPS、ARPG、ACT、Rougelike 类型游戏。</p>
        <p>whiskey / cocktail 品鉴者，尤其中意 Negroni。</p>
        <p>健身小白。</p>
      </div>
    </div>
  </Section>

  <section class="p-4 max-w-2xl mx-auto pb-20">
    <div class="space-y-14">
      <div class="space-y-3">
        <h2 class="text-3xl font-semibold sm:text-4xl">游戏</h2>
        <p class="text-sm leading-7 opacity-80 sm:text-base">
          这里按不同方式整理了我最喜欢、投入时间最多，以及认真打 through 的游戏。
        </p>
      </div>

      {aboutGameGroups.map((group) => <GameSection group={group} />)}
    </div>
  </section>
</Layout>
